{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' pnpm --filter './apps/*' dev",
    "build": "pnpm --filter './apps/*' build",
    "build:server": "NODE_OPTIONS=\"--max-old-space-size=512\" UV_THREADPOOL_SIZE=1 pnpm --filter './apps/*' --workspace-concurrency=1 build",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "db:reset:danger": "pnpm --filter @repo/service db:reset:danger",
    "db:generate": "pnpm --filter @repo/service db:generate",
    "db:push": "pnpm --filter @repo/service db:push",
    "db:seed": "pnpm --filter @repo/service db:seed",
    "db:migrate": "pnpm --filter @repo/service db:migrate",
    "db:migrate:deploy": "pnpm --filter @repo/service db:migrate:deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
